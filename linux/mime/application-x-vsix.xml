    <comment>VS Code Extension Package</comment>
    <glob pattern="*.vsix" weight="90"/>
    <sub-class-of type="application/zip"/>
    <icon name="application-x-vsix"/>
    <generic-icon name="package-x-generic"/>
  </mime-type>
</mime-info>
