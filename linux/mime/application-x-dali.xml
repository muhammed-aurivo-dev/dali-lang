<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns='http://www.freedesktop.org/standards/shared-mime-info'>
  <mime-type type="application/x-dali">
    <comment>Dali Audio DSL Source</comment>
    <glob pattern="*.dali" weight="90"/>
    <glob pattern="*.dl" weight="90"/>
    <alias type="text/x-dali"/>
    <sub-class-of type="text/plain"/>
    <icon name="dali-file"/>
    <generic-icon name="text-x-generic"/>
  </mime-type>
</mime-info>
