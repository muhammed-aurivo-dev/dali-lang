{
  "name": "DALI",
  "scopeName": "source.dali",
  "fileTypes": [
    "dali",
    "dl"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#effects"
    },
    {
      "include": "#sectionNames"
    },
    {
      "include": "#targets"
    },
    {
      "include": "#paramNames"
    },
    {
      "include": "#bandCall"
    },
    {
      "include": "#propertyKey"
    },
    {
      "include": "#assignmentIdentifier"
    },
    {
      "include": "#numbersWithUnits"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dali",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dali",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.dali",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dali",
          "match": "\\b(preset|engine|chain|quality|input|output|safety|profile|strict|realtime|on|off)\\b"
        }
      ]
    },
    "effects": {
      "patterns": [
        {
          "name": "support.function.effect.dali",
          "match": "\\b(preamp|eq32|band|peaking|limiter|compressor|low_shelf|high_shelf|reverb|bassboost|deesser|exciter|stereowidener|echo|noisegate|autogain|truepeak|dynamiceq|crossfeed|surround|bassmono|tapesat|bitdither|module)\\b"
        }
      ]
    },
    "sectionNames": {
      "patterns": [
        {
          "name": "entity.name.section.dali",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\{)"
        }
      ]
    },
    "targets": {
      "patterns": [
        {
          "name": "support.type.target.dali",
          "match": "\\b(web|speakers|music)\\b"
        }
      ]
    },
    "paramNames": {
      "patterns": [
        {
          "name": "variable.parameter.key.dali",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*[:=])"
        }
      ]
    },
    "bandCall": {
      "patterns": [
        {
          "name": "meta.function-call.band.dali",
          "match": "\\b(band)(\\s*)(\\()(\\s*-?(?:\\d+\\.\\d+|\\d+)(?:hz|ms|db|x)?\\s*)(\\))",
          "captures": {
            "1": {
              "name": "support.function.effect.dali"
            },
            "3": {
              "name": "punctuation.section.group.begin.dali"
            },
            "4": {
              "name": "constant.numeric.unit.inline.dali"
            },
            "5": {
              "name": "punctuation.section.group.end.dali"
            }
          }
        }
      ]
    },
    "propertyKey": {
      "patterns": [
        {
          "name": "variable.other.property.dali",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*:)"
        }
      ]
    },
    "assignmentIdentifier": {
      "patterns": [
        {
          "name": "variable.parameter.assignment.dali",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*=)"
        }
      ]
    },
    "numbersWithUnits": {
      "patterns": [
        {
          "name": "meta.number-with-unit.dali",
          "match": "\\b(-?(?:\\d+\\.\\d+|\\d+))(hz|ms|db|x|%)\\b",
          "captures": {
            "1": {
              "name": "constant.numeric.dali"
            },
            "2": {
              "name": "keyword.other.unit.dali"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.dali",
          "match": "\\b-?(?:\\d+\\.\\d+|\\d+)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dali",
          "match": "[=:.(),;{}]"
        }
      ]
    }
  }
}
